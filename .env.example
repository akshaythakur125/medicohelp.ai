# ── AI Provider (choose one) ──────────────────────────────────────────────
# Recommended: Anthropic Claude (cheapest + highest quality for medical content)
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=

# OpenAI alternative
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Google Gemini alternative (has free tier)
# AI_PROVIDER=gemini
# AI_MODEL=gemini-1.5-flash
# GEMINI_API_KEY=

# Set AI_PROVIDER=none and leave keys empty for zero-API (library-only) mode
ALLOW_MOCK_AI=true        # true = use library content if no API key

# ── Image generation (optional, leave false for cloud/text-only mode) ─────────
GENERATE_REALISTIC_IMAGES=false
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # From @BotFather — create a bot, copy the token
TELEGRAM_CHAT_ID=          # Channel/group ID e.g. -100123456789 (add bot as admin first)
ADMIN_CHAT_ID=             # Your personal chat ID for /status /post commands (optional)
                           # To find it: message your bot, then GET /getUpdates

# ── Instagram ─────────────────────────────────────────────────────
# Step 1: Create a Facebook Developer App at https://developers.facebook.com/
# Step 2: Link your Instagram Business/Creator account to a Facebook Page
# Step 3: Get an access token with these permissions:
#         instagram_basic, instagram_content_publish, pages_read_engagement
# Step 4: Find your Instagram User ID:
#         GET https://graph.facebook.com/me?fields=id,name&access_token=YOUR_TOKEN
#
INSTAGRAM_ENABLED=false
INSTAGRAM_USER_ID=          # Numeric Instagram User ID (e.g., 17841400000000000)
INSTAGRAM_ACCESS_TOKEN=     # Long-lived User Access Token (60-day, refreshable)
#
# imgbb.com hosts images publicly so Instagram Graph API can fetch them.
# Free account: https://imgbb.com/ -> API -> Get API Key
IMGBB_API_KEY=              # imgbb.com free API key

# ── Scheduling ─────────────────────────────────────────────────────
POST_SCHEDULE_TIMES=08:00,14:00,20:00   # Fixed cron slots (IST). Leave empty for interval mode.
POST_INTERVAL_HOURS=6                    # Used only when POST_SCHEDULE_TIMES is empty
TIMEZONE=Asia/Kolkata
RUN_SCHEDULER=true
POSTING_PAUSED=false                     # Start paused. Toggle via /pause and /resume

# ── Post mode ─────────────────────────────────────────────────────
TEXT_ONLY_MODE=true        # true = send rich-text messages (no Pillow/image generation)
                           # false = generate image poster and send as photo

# ── App ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
NEWS_LOOKBACK_DAYS=14
NEWS_MAX_ITEMS=6
